# ==========================================
# HERITAGE RWA AUCTION - ENVIRONMENT VARIABLES
# ==========================================
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to Git (it's already in .gitignore)

# ------------------------------------------
# THIRDWEB - Web3 Wallet Infrastructure
# ------------------------------------------
# Get your Client ID from: https://thirdweb.com/dashboard
# Required for Connect Wallet functionality
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=381981d013ed01f1f9bbb2c0a20b5c6d

# ------------------------------------------
# SANITY CMS - Content Management
# ------------------------------------------
# Get your Project ID from: https://www.sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=4p36d55f
NEXT_PUBLIC_SANITY_DATASET=production

# Optional: Only needed for write operations (migrations, etc.)
# Get from Sanity dashboard: API > Tokens
# SANITY_API_TOKEN=your_sanity_api_token_here

# ------------------------------------------
# VERCEL ANALYTICS (Optional - auto-configured by Vercel)
# ------------------------------------------
# These are auto-set when you deploy to Vercel, no manual config needed
# VERCEL_ANALYTICS_ID=
# VERCEL_SPEED_INSIGHTS_ID=

# ------------------------------------------
# OPTIONAL: Custom RPC (for faster Web3 reads)
# ------------------------------------------
# NEXT_PUBLIC_ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# ==========================================
# SETUP INSTRUCTIONS:
# ==========================================
# 1. Copy this file: cp .env.example .env.local
# 2. Fill in your actual values in .env.local
# 3. Run: npm run dev
# 4. For production, add these to Vercel Dashboard
# ==========================================
